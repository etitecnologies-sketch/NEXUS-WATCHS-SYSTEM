{
  "version": "2",
  "services": {
    "server": {
      "source": {
        "directory": "nexus-watchs"
      },
      "build": {
        "builder": "nixpacks"
      },
      "deploy": {
        "startCommand": "pnpm start"
      }
    },
    "ingest-api": {
      "source": {
        "directory": "monitoring-system/ingest-api"
      },
      "build": {
        "builder": "nixpacks"
      },
      "deploy": {
        "startCommand": "node index.js"
      }
    },
    "websocket": {
      "source": {
        "directory": "monitoring-system/websocket-server"
      },
      "build": {
        "builder": "nixpacks"
      },
      "deploy": {
        "startCommand": "node index.js"
      }
    },
    "processor": {
      "source": {
        "directory": "monitoring-system/processor"
      },
      "build": {
        "builder": "nixpacks"
      },
      "deploy": {
        "startCommand": "sh start.sh"
      }
    },
    "frontend": {
      "source": {
        "directory": "nexus-watchs/client"
      },
      "build": {
        "builder": "nixpacks"
      },
      "deploy": {
        "startCommand": "pnpm dev"
      }
    }
  }
}
